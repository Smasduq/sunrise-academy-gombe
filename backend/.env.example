# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth
SECRET_KEY=change-me-to-a-long-random-string

# CORS (comma-separated)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001

# Hugging Face bucket (images)
# Create a token at https://huggingface.co/settings/tokens (write access)
# Bucket ID format: username/bucket-name (from your bucket page URL)
HF_TOKEN=hf_your_token_here
HF_BUCKET_ID=your-username/your-bucket-name
