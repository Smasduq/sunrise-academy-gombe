# FastAPI backend — set this on Vercel (NOT API_URL; Vercel may auto-overwrite API_URL).
BACKEND_API_URL=http://127.0.0.1:8000

# NextAuth
AUTH_SECRET=replace-with-a-long-random-secret

# AUTH_URL is not needed — auth.config.ts sets trustHost: true so the app URL
# is taken from incoming request headers (works for local dev and production).
