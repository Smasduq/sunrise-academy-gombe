# FastAPI backend URL (local dev default: http://127.0.0.1:8000)
# On Vercel: set BACKEND_API_URL in Dashboard → Settings → Environment Variables.
# Do NOT use a .vercel.app URL — use your Railway/Render FastAPI host.
# Remove any API_URL variable Vercel may have auto-created.
BACKEND_API_URL=http://127.0.0.1:8000

# NextAuth
AUTH_SECRET=replace-with-a-long-random-secret

# AUTH_URL is not needed — auth.config.ts sets trustHost: true so the app URL
# is taken from incoming request headers (works for local dev and production).
